from gds3xtrude.include import layer

poly2 = layer(30, 0)
contact = layer(33, 0)
metal1 = layer(34, 0)
via1 = layer(35, 0)
metal2 = layer(36, 0)

# Optional colors: RGB values from 0 to 1
poly2.color   = [0.8, 0.2, 0.2]
contact.color = [0.6, 0.6, 0.6]
metal1.color = [0.2, 0.2, 0.8]
via1.color   = [0.7, 0.7, 0.7]
metal2.color = [0.2, 0.8, 0.2]

# Layer stack: each tuple is (height/thickness, layer or [layers])
layerstack = [
    (20, poly2),
    (100, contact),
    (50, metal1),
    (100, via1),
    (50, metal2),
]
